{
  "name": "bluffalo",
  "version": "1.0.0",
  "description": "Bluffalo - Fibbage-inspired multiplayer social deception game",
  "private": true,
  "scripts": {
    "dev:client": "cd client && vite",
    "dev:server": "cd server && ts-node-dev --respawn --transpile-only src/index.ts",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "poll": "ts-node scripts/poll-reported-facts.ts",
    "build:client": "cd client && vite build --outDir ../server/public",
    "build:server": "cd server && tsc",
    "build": "npm run build:client && npm run build:server",
    "start": "node server/dist/server/src/index.js"
  },
  "dependencies": {
    "@types/dotenv": "^8.2.3",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.2",
    "tailwindcss": "^3.3.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.8"
  }
}
